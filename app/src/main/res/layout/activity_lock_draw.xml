<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1F2E">

    <!-- Leinwand endet über dem Dock (bottomMargin wird in Code gesetzt) -->
    <com.luv.couple.lock.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top" />

    <TextView
        android:id="@+id/lobbyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="72dp"
        android:layout_marginTop="16dp"
        android:elevation="6dp"
        android:ellipsize="end"
        android:letterSpacing="0.04"
        android:maxLines="1"
        android:shadowColor="#66000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:textColor="@color/ink_white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Reaktionen: 🙂 oben rechts, klappt nach unten aus -->
    <LinearLayout
        android:id="@+id/reactionPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/vote_card_bg"
        android:elevation="10dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="6dp">

        <TextView
            android:id="@+id/btnReactionToggle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🙂"
            android:textSize="22sp" />

        <LinearLayout
            android:id="@+id/reactionFlyout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- width/height explizit: LuvEmojiBtn hat 0dp+weight (nur für horizontale Leiste) -->
            <TextView
                android:id="@+id/emoji0"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_marginTop="2dp"
                android:layout_weight="0"
                android:text="👍" />

            <TextView
                android:id="@+id/emoji1"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:text="❌" />

            <TextView
                android:id="@+id/emoji2"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:text="❤️" />

            <TextView
                android:id="@+id/emoji3"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:text="😂" />

            <TextView
                android:id="@+id/emoji4"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:text="😱" />

            <TextView
                android:id="@+id/emoji5"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:text="😡" />

            <TextView
                android:id="@+id/emoji6"
                style="@style/LuvEmojiBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:layout_weight="0"
                android:text="😭" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/gameHud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/vote_card_bg"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/gameHudTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/ink_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/gameHudSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnGuess"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/lock_dock_slot_active"
            android:gravity="center"
            android:text="@string/game_guess_btn"
            android:textColor="@color/ink_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <com.luv.couple.lock.GamePlayOverlay
        android:id="@+id/gamePlayOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <TextView
        android:id="@+id/missedBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="72dp"
        android:alpha="0"
        android:background="@drawable/vote_card_bg"
        android:elevation="8dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textColor="@color/ink_white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/reactionBurst"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:alpha="0"
        android:textSize="64sp" />

    <TextView
        android:id="@+id/statusDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="56dp"
        android:alpha="0"
        android:background="@drawable/vote_card_bg"
        android:elevation="8dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:textColor="@color/ink_white"
        android:textSize="13sp"
        android:visibility="gone" />

    <HorizontalScrollView
        android:id="@+id/legendScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="72dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/legendRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="bottom|center_horizontal"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp" />
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/bottomDock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/lock_dock_bg"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/dockPill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/lock_dock_pill"
            android:orientation="vertical"
            android:padding="6dp">

            <LinearLayout
                android:id="@+id/actionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/lock_dock_slot"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="←"
                    android:textColor="@color/ink_white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/lock_dock_slot"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:contentDescription="@string/save_moment_short"
                    android:text="📷"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/btnGame"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/lock_dock_slot"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="🎮"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/lock_dock_slot"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:contentDescription="@string/clear_canvas"
                    android:text="🗑"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/btnEraser"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/lock_dock_slot"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:contentDescription="@string/eraser_toggle"
                    android:text="🧽"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/btnColor"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/lock_dock_slot"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="🎨"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
