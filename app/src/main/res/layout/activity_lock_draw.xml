<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/male_blue">

    <TextView
        android:id="@+id/lockClock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="72dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@color/ink_white"
        android:textSize="72sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lockDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="150dp"
        android:gravity="center"
        android:textColor="@color/ink_white"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/presenceRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/presenceDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/presence_dot"
            android:alpha="0.35" />

        <TextView
            android:id="@+id/presenceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/partner_away"
            android:textColor="@color/ink_white"
            android:textSize="12sp" />
    </LinearLayout>

    <com.luv.couple.lock.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/noteBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:alpha="0"
        android:background="@drawable/note_banner_bg"
        android:gravity="center"
        android:paddingHorizontal="18dp"
        android:paddingVertical="14dp"
        android:textColor="@color/ink_white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/missedBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="190dp"
        android:alpha="0"
        android:background="@drawable/note_banner_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="@string/missed_you"
        android:textColor="@color/ink_white"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/statusDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.75"
            android:text="@string/draw_hint"
            android:textColor="@color/ink_white"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/lock_action_btn"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/send_note"
                android:textColor="@color/ink_white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/lock_action_btn"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/save_moment"
                android:textColor="@color/ink_white"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
