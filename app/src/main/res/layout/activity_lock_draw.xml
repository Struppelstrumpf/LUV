<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1F2E">

    <com.luv.couple.lock.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/lobbyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:elevation="6dp"
        android:letterSpacing="0.04"
        android:shadowColor="#66000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:textColor="@color/ink_white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnColor"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/lock_circle_btn"
        android:clickable="true"
        android:elevation="8dp"
        android:focusable="true"
        android:gravity="center" />

    <TextView
        android:id="@+id/reactionBurst"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:alpha="0"
        android:elevation="12dp"
        android:textSize="72sp" />

    <TextView
        android:id="@+id/missedBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="72dp"
        android:alpha="0"
        android:background="@drawable/note_banner_bg"
        android:elevation="6dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="@string/missed_you"
        android:textColor="@color/ink_white"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/bottomDock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/lock_dock_bg"
        android:elevation="10dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="22dp">

        <HorizontalScrollView
            android:id="@+id/legendScroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/legendRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/legend_chip_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/emojiRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/emoji0"
                style="@style/LuvEmojiBtn"
                android:text="👍" />

            <TextView
                android:id="@+id/emoji1"
                style="@style/LuvEmojiBtn"
                android:text="😮" />

            <TextView
                android:id="@+id/emoji2"
                style="@style/LuvEmojiBtn"
                android:text="😍" />

            <TextView
                android:id="@+id/emoji3"
                style="@style/LuvEmojiBtn"
                android:text="😢" />

            <TextView
                android:id="@+id/emoji4"
                style="@style/LuvEmojiBtn"
                android:text="❤️" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/lock_circle_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/ink_white"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/lock_pill_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:text="@string/save_moment"
                android:textColor="@color/ink_white"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btnGame"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/lock_circle_btn"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="🎮"
                android:textSize="22sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/statusDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.55"
                android:gravity="end"
                android:maxWidth="140dp"
                android:text="@string/draw_hint"
                android:textColor="@color/ink_white"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
