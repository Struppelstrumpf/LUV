<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/male_blue">

    <ImageView
        android:id="@+id/canvasImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/widget_name"
        android:scaleType="fitXY" />

    <TextView
        android:id="@+id/liveBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="14dp"
        android:background="@drawable/widget_live_badge"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:shadowColor="#99000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4"
        android:text="@string/widget_live_now"
        android:textColor="@color/ink_white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tapHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:alpha="0.75"
        android:text="@string/open_canvas"
        android:textColor="@color/ink_white"
        android:textSize="13sp" />
</FrameLayout>
