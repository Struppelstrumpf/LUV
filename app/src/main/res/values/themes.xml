<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Edge-to-edge: Systemleisten transparent; Farben steuert enableEdgeToEdge() -->
    <style name="Theme.LUV" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Lock-Leinwand: kein windowFullscreen (deprecated) — Immersive via WindowInsetsController -->
    <style name="Theme.LUV.Lock" parent="Theme.LUV">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowShowWallpaper">false</item>
    </style>

    <style name="LuvEmojiBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginHorizontal">2dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/lock_emoji_btn</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">1</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>
